{
  "name": "spark-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --experimental-sqlite --disable-warning=ExperimentalWarning server/index.mjs",
    "dev:full": "node --experimental-sqlite --disable-warning=ExperimentalWarning server/index.mjs & vite",
    "kill": "fuser -k 5173/tcp 8787/tcp",
    "build": "npm run build:core",
    "build:core": "tsc -b --noCheck && vite build",
    "build:direct": "bash ./scripts/build-direct.sh",
    "lint": "eslint .",
    "test": "vitest run",
