# GitHub OAuth App Client ID (optional)
# Create an OAuth App at https://github.com/settings/developers
# Enable "Device Flow" in the OAuth App settings.
# The Client ID is NOT a secret and is safe to commit.
#
# When set, a "Sign in with GitHub" button appears on the login page,
# allowing users to authenticate via the GitHub Device Authorization Flow.
# The resulting OAuth token is used for GitHub Models (AI scanning) and
# is stored only in the browser's localStorage.
#
# Both nginx (production) and the Vite dev server proxy /github-oauth/ to
# https://github.com/ so that device-flow requests stay same-origin and
# avoid browser CORS restrictions.
#
# If not set, users must enter a Personal Access Token manually.
VITE_GITHUB_CLIENT_ID=

# ── Server security (optional) ─────────────────────────────────────────────

# ALLOWED_ORIGIN — Cross-Origin Resource Sharing (CORS)
# Leave empty (default) for same-origin / single-host deployments where the
# Node server serves both the API and the built frontend.
# Set to the exact frontend origin (e.g. http://localhost:5173) only when the
# frontend and API run on different origins (e.g. during development with
# `npm run dev:full`).
ALLOWED_ORIGIN=

# API_SECRET — shared-secret protection for mutating endpoints
# If set, all POST / PUT / DELETE requests and GET /api/db/export must include
#   Authorization: Bearer <secret>
# Leave empty (default) for local / trusted-network deployments.
API_SECRET=

# VITE_API_SECRET — must match API_SECRET so the frontend includes the header.
# This value is embedded in the built JS bundle; use only on trusted networks.
VITE_API_SECRET=
