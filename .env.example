# ── AI Provider ────────────────────────────────────────────────────────────
# Which AI provider to use for card image recognition.
# Options: github | openai | groq | ollama | azure
AI_PROVIDER=github

# GitHub Models (default, used when AI_PROVIDER=github)
# Get a free PAT at: https://github.com/settings/tokens/new
GITHUB_MODELS_TOKEN=

# OpenAI (used when AI_PROVIDER=openai)
OPENAI_API_KEY=

# Groq (used when AI_PROVIDER=groq)
# Get a free key at: https://console.groq.com
GROQ_API_KEY=

# Ollama (used when AI_PROVIDER=ollama — runs locally, no key needed)
OLLAMA_BASE_URL=http://localhost:11434

# Azure OpenAI (used when AI_PROVIDER=azure)
AZURE_OPENAI_URL=
AZURE_OPENAI_API_KEY=

# Model name override — must be a vision-capable model supported by your chosen provider.
# Defaults differ per provider if not set; set this explicitly to control exactly which model is used.
# Examples:
#   GitHub Models:  meta/llama-4-maverick-17b-128e-instruct-fp8  (default)
#   OpenAI:         gpt-4o
#   Groq:           meta-llama/llama-4-scout-17b-16e-instruct
#   Ollama:         llava
VITE_CARD_ANALYSIS_MODEL=

# ── Server security (optional) ─────────────────────────────────────────────

# ALLOWED_ORIGIN — Cross-Origin Resource Sharing (CORS)
# Leave empty (default) for same-origin / single-host deployments where the
# Node server serves both the API and the built frontend.
# Set to the exact frontend origin (e.g. http://localhost:5173) only when the
# frontend and API run on different origins (e.g. during development with
# `npm run dev:full`).
ALLOWED_ORIGIN=

# API_SECRET — shared-secret protection for mutating endpoints
# If set, all POST / PUT / DELETE requests and GET /api/db/export require
# a valid session cookie obtained via POST /api/auth/login.
# The frontend will prompt for the password at runtime — it is NEVER compiled
# into the JavaScript bundle.
# Leave empty (default) for local / trusted-network deployments.
API_SECRET=
